# Plaid API credentials (production).
# Get these from the Plaid dashboard: https://dashboard.plaid.com → Team Settings → API.
# Use the production secret (not sandbox) to talk to real bank data.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production

# Per-Item access tokens — one per linked bank.
# Populated by running `uvicorn link_helper:app --port 8765` locally (see README).
# Pattern: PLAID_TOKEN_<INSTITUTION_NAME_UPPERCASE>
# Examples (add/remove as you link banks):
# PLAID_TOKEN_CHASE=
# PLAID_TOKEN_FIDELITY=
# PLAID_TOKEN_AMEX=

# Deployment guard — set to any truthy value in your deployment environment.
# When set, `link_helper.py` refuses to run (it's a local-only tool). Leave
# unset locally so the helper works.
# HORIZON=1
